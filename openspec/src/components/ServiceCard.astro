---
interface Props {
  service: {
    id: string;
    name: string;
    description: string;
    price: string;
    status: string;
    repo?: string;
  }
}

const { service } = Astro.props;
---

<div class="service-card">
  <div class="status">{service.status}</div>
  <h3>{service.name}</h3>
  <p>{service.description}</p>
  {service.repo && (
    <p class="repo">
      <a href={`https://github.com/SmarterCL/${service.repo}`} target="_blank">
        📦 {service.repo}
      </a>
    </p>
  )}
  <div class="price">{service.price}</div>
  <a href={`https://app.smarterbot.cl/services/${service.id}`} class="btn">
    Contratar
  </a>
</div>

<style>
  .service-card {
    border: 1px solid #ddd;
    padding: 1.5rem;
    border-radius: 8px;
    position: relative;
    background: white;
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .service-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 16px rgba(0,0,0,0.1);
  }

  .status {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: #4caf50;
    color: white;
    padding: 0.25rem 0.5rem;
    border-radius: 4px;
    font-size: 0.75rem;
    font-weight: 600;
    text-transform: uppercase;
  }

  h3 {
    margin-bottom: 0.5rem;
    color: #0066cc;
    font-size: 1.25rem;
  }

  p {
    color: #666;
    margin-bottom: 0.5rem;
  }

  .repo {
    font-size: 0.85rem;
    margin: 1rem 0;
  }

  .repo a {
    color: #0066cc;
    text-decoration: none;
  }

  .repo a:hover {
    text-decoration: underline;
  }

  .price {
    font-weight: bold;
    color: #0066cc;
    margin: 1rem 0;
    font-size: 1.1rem;
  }

  .btn {
    display: inline-block;
    background: #0066cc;
    color: white;
    padding: 0.5rem 1rem;
    text-decoration: none;
    border-radius: 4px;
    font-weight: 600;
    transition: background 0.2s;
  }

  .btn:hover {
    background: #0055aa;
  }
</style>
